# .env.production.example — Production Environment Variables

# ─── Server ────────────────────────────────────────────────
PORT=8080
APP_ENV=production          # Must be "production" in production

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@your-db-host:5432/your-db-name
# DB_POOL_SIZE=10           # Optional: connection pool max size

# ─── Security ──────────────────────────────────────────────
JWT_SECRET=replace-with-at-least-32-random-chars-never-commit-this
JWT_EXPIRATION=86400        # seconds — 24 hours

# ─── Application ───────────────────────────────────────────
# LOG_LEVEL=info            # debug | info | warn | error
# SENTRY_DSN=               # Error monitoring (optional)

# ─── ORM (Production Safety) ───────────────────────────────
# DDL_AUTO=validate         # NEVER use "create" or "update" in production
# SHOW_SQL=false            # NEVER expose SQL logs in production

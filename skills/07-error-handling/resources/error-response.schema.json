{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ErrorResponse",
  "description": "Standard error response shape for any backend API (Skill 07 - error-handling)",
  "type": "object",
  "required": ["timestamp", "status", "error", "message", "path"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when the error occurred",
      "example": "2025-06-15T10:30:00.000Z"
    },
    "status": {
      "type": "integer",
      "description": "HTTP status code",
      "enum": [400, 401, 403, 404, 409, 422, 500],
      "example": 404
    },
    "error": {
      "type": "string",
      "description": "Short name of the HTTP error",
      "examples": ["Not Found", "Bad Request", "Forbidden", "Conflict", "Internal Server Error"]
    },
    "message": {
      "type": "string",
      "description": "Human-readable, client-safe error message. Never include stack traces or internal details.",
      "example": "Order not found: 99"
    },
    "path": {
      "type": "string",
      "description": "The request path that caused the error",
      "example": "/api/orders/99"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "timestamp": "2025-06-15T10:30:00.000Z",
      "status": 404,
      "error": "Not Found",
      "message": "Order not found: 99",
      "path": "/api/orders/99"
    },
    {
      "timestamp": "2025-06-15T10:31:00.000Z",
      "status": 400,
      "error": "Bad Request",
      "message": "name: must not be blank, price: must be greater than 0",
      "path": "/api/products"
    },
    {
      "timestamp": "2025-06-15T10:32:00.000Z",
      "status": 500,
      "error": "Internal Server Error",
      "message": "An unexpected error occurred",
      "path": "/api/orders"
    }
  ]
}
